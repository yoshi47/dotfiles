{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 1000,
  "includeCoAuthoredBy": false,
  "skipDangerousModePermissionPrompt": true,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(pnpm type-check:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm unit-test:*)",
      "Bash(pnpm format:*)",
      "Bash(pnpm openapi:*)",
      "Bash(pnpm run type-check:*)",
      "Bash(cd web && pnpm type-check:*)",
      "Bash(npm run format:*)",
      "Bash(npm run type-check:*)",
      "Bash(npm test)",
      "Bash(yarn type-check)",
      "Bash(yarn lint)",
      "Bash(yarn lint:*)",
      "Bash(yarn test:*)",
      "Bash(yarn jest:*)",
      "Bash(yarn tsx:*)",
      "Bash(yarn tsc:*)",
      "Bash(yarn openapi:*)",
      "Bash(yarn biome check:*)",
      "Bash(yarn install)",
      "Bash(npx tsc:*)",
      "Bash(npx biome check:*)",
      "Bash(npx jest:*)",
      "Bash(NODE_OPTIONS=\"--max-old-space-size=8192\" npx tsc --noEmit --incremental)",
      "Bash(timeout 60 pnpm test -- --testPathPattern=\"DocumentsList\" --verbose --no-watch)",
      "Bash(timeout 60 yarn test estimates.service.spec.ts --testNamePattern=\"findOne\")",
      "Bash(PRISMA_LOG_QUERIES=true yarn dev)",
      "Bash(./run-knip-and-squash.sh:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(echo:*)",
      "Bash(chmod:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(mkdir:*)",
      "Bash(ln:*)",
      "Bash(sed:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(nvm use)",
      "Bash(nvm:*)",
      "Bash(git show:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git push:*)",
      "Bash(gh search:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue status:*)",
      "Bash(gh repo view:*)",
      "Bash(gh repo list:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run watch:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh workflow view:*)",
      "Bash(gh release list:*)",
      "Bash(gh release view:*)",
      "Bash(gh status:*)",
      "Bash(gh browse:*)",
      "Bash(gh label list:*)",
      "Bash(gh cache list:*)",
      "Bash(playwright-cli:*)",
      "Bash(npx playwright-cli:*)",
      "WebFetch(domain:*)",
      "WebSearch",
      "List(*)",
      "Skill(*)",
      "Write(/tmp/pr_body.md)",
      "mcp__figma__get_figma_data",
      "mcp__ide__executeCode",
      "mcp__ide__getDiagnostics",
      "mcp__postgres__query",
      "mcp__notion__API-get-self",
      "mcp__notion__API-get-users",
      "mcp__notion__API-get-block-children",
      "mcp__notion__API-post-database-query",
      "mcp__notion__API-post-search",
      "mcp__notion__API-retrieve-a-database",
      "mcp__notion__API-retrieve-a-page",
      "mcp__notionApi__API-get-self",
      "mcp__notionApi__API-get-user",
      "mcp__notionApi__API-get-users",
      "mcp__notionApi__API-get-block-children",
      "mcp__notionApi__API-retrieve-a-block",
      "mcp__notionApi__API-retrieve-a-comment",
      "mcp__notionApi__API-retrieve-a-data-source",
      "mcp__notionApi__API-retrieve-a-database",
      "mcp__notionApi__API-retrieve-a-page",
      "mcp__notionApi__API-retrieve-a-page-property",
      "mcp__notionApi__API-list-data-source-templates",
      "mcp__notionApi__API-query-data-source",
      "mcp__notionApi__API-post-search",
      "mcp__serena__check_onboarding_performed",
      "mcp__serena__find_file",
      "mcp__serena__find_referencing_symbols",
      "mcp__serena__find_symbol",
      "mcp__serena__get_symbols_overview",
      "mcp__serena__list_dir",
      "mcp__serena__search_for_pattern",
      "mcp__serena__write_memory",
      "mcp__plugin_claude-mem_mcp-search__search",
      "mcp__claude_ai_Slack__slack_search_public_and_private"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm remove:*)",
      "Bash(printenv:*)",
      "Bash(psql:*)",
      "Bash(mysql:*)",
      "Bash(mongod:*)",
      "Bash(pnpm reset:*)",
      "Read(.env*)",
      "Read(.envrc*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/*token*)",
      "Read(**/*_key)",
      "Write(.env*)",
      "Write(**/secrets/**)",
      "mcp__supabase__execute_sql",
      "mcp__notionApi__API-create-a-comment",
      "mcp__notionApi__API-create-a-data-source",
      "mcp__notionApi__API-delete-a-block",
      "mcp__notionApi__API-move-page",
      "mcp__notionApi__API-patch-block-children",
      "mcp__notionApi__API-patch-page",
      "mcp__notionApi__API-post-page",
      "mcp__notionApi__API-update-a-block",
      "mcp__notionApi__API-update-a-data-source"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay ~/Documents/notification.wav > /dev/null 2>&1 &"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/hook_stop_words.sh ${MESSAGE}"
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/hook_fetch.sh ${MESSAGE}"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "git-ai checkpoint claude --hook-input stdin"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/bash_timeout_notifier.sh ${MESSAGE}"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "git-ai checkpoint claude --hook-input stdin"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/plugins/cache/work-checkpoints-plugin/work-checkpoints/1.0.3/scripts/save-checkpoint.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay ~/Documents/celebration.wav > /dev/null 2>&1 &"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": [],
    "filesystem": {
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.gnupg",
        "~/.config/gh"
      ],
      "allowWrite": [
        "//tmp",
        "~/.npm",
        "~/.cache",
        "~/.local/share/mise"
      ]
    },
    "network": {
      "allowLocalBinding": true,
      "allowedDomains": [
        "registry.npmjs.org",
        "*.npmjs.org",
        "github.com",
        "*.github.com",
        "*.githubusercontent.com",
        "registry.yarnpkg.com",
        "api.anthropic.com"
      ],
      "allowUnixSockets": [],
      "allowAllUnixSockets": false
    }
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/statusline.js"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "work-checkpoints@work-checkpoints-plugin": true,
    "swift-lsp@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "claude-mem@thedotmack": true
  },
  "extraKnownMarketplaces": {
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    }
  },
  "feedbackSurveyState": {
    "lastShownTime": 1754035909681
  }
}
