{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "skipDangerousModePermissionPrompt": true,
  "includeCoAuthoredBy": false,
  "cleanupPeriodDays": 99999,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_ENABLE_PROMPT_SUGGESTION": "true"
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "WebFetch(domain:*)",
      "WebSearch",
      "List(*)",
      "Skill(*)",
      "Write(/tmp/pr_body.md)",

      "Bash(ls:*)",
      "Bash(echo:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sed:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(mkdir:*)",
      "Bash(ln:*)",
      "Bash(chmod:*)",
      "Bash(curl:*)",

      "Bash(git show:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git push:*)",
      "Bash(git cat-file:*)",
      "Bash(git rev-parse:*)",

      "Bash(gh search:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue status:*)",
      "Bash(gh repo view:*)",
      "Bash(gh repo list:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run watch:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh workflow view:*)",
      "Bash(gh release list:*)",
      "Bash(gh release view:*)",
      "Bash(gh status:*)",
      "Bash(gh browse:*)",
      "Bash(gh label list:*)",
      "Bash(gh cache list:*)",

      "Bash(nvm use)",
      "Bash(nvm:*)",
      "Bash(nodenv shell:*)",

      "Bash(pnpm type-check:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm unit-test:*)",
      "Bash(pnpm format:*)",
      "Bash(pnpm openapi:*)",
      "Bash(pnpm run type-check:*)",
      "Bash(pnpm jest:*)",
      "Bash(cd web && pnpm type-check:*)",
      "Bash(timeout 60 pnpm test -- --testPathPattern=\"DocumentsList\" --verbose --no-watch)",
      "Bash(timeout 120 pnpm test:*)",
      "Bash(pnpm reset:*)",

      "Bash(npm run format:*)",
      "Bash(npm run type-check:*)",
      "Bash(npm test)",

      "Bash(yarn type-check)",
      "Bash(yarn lint)",
      "Bash(yarn lint:*)",
      "Bash(yarn test:*)",
      "Bash(yarn jest:*)",
      "Bash(yarn tsx:*)",
      "Bash(yarn tsc:*)",
      "Bash(yarn openapi:*)",
      "Bash(yarn biome check:*)",
      "Bash(yarn install)",
      "Bash(timeout 60 yarn test estimates.service.spec.ts --testNamePattern=\"findOne\")",
      "Bash(PRISMA_LOG_QUERIES=true yarn dev)",

      "Bash(npx tsc:*)",
      "Bash(npx biome check:*)",
      "Bash(npx jest:*)",
      "Bash(NODE_OPTIONS=\"--max-old-space-size=8192\" npx tsc --noEmit --incremental)",

      "Bash(playwright-cli:*)",
      "Bash(npx playwright-cli:*)",
      "Skill(playwright-cli)",
      "Skill(review)",
      "Bash(./run-knip-and-squash.sh:*)",
      "Bash(./scripts/fetch-notion-ticket.sh:*)",

      "mcp__figma__get_figma_data",
      "mcp__ide__executeCode",
      "mcp__ide__getDiagnostics",
      "mcp__postgres__query",
      "mcp__datadog__search_datadog_dashboards",

      "mcp__notion__API-get-self",
      "mcp__notion__API-get-users",
      "mcp__notion__API-get-block-children",
      "mcp__notion__API-post-database-query",
      "mcp__notion__API-post-search",
      "mcp__notion__API-retrieve-a-database",
      "mcp__notion__API-retrieve-a-page",

      "mcp__notionApi__API-get-self",
      "mcp__notionApi__API-get-user",
      "mcp__notionApi__API-get-users",
      "mcp__notionApi__API-get-block-children",
      "mcp__notionApi__API-retrieve-a-block",
      "mcp__notionApi__API-retrieve-a-comment",
      "mcp__notionApi__API-retrieve-a-data-source",
      "mcp__notionApi__API-retrieve-a-database",
      "mcp__notionApi__API-retrieve-a-page",
      "mcp__notionApi__API-retrieve-a-page-property",
      "mcp__notionApi__API-list-data-source-templates",
      "mcp__notionApi__API-query-data-source",
      "mcp__notionApi__API-post-search",

      "mcp__claude_ai_Notion__notion-search",
      "mcp__claude_ai_Notion__notion-fetch",

      "mcp__serena__check_onboarding_performed",
      "mcp__serena__activate_project",
      "mcp__serena__find_file",
      "mcp__serena__find_referencing_symbols",
      "mcp__serena__find_symbol",
      "mcp__serena__get_symbols_overview",
      "mcp__serena__list_dir",
      "mcp__serena__search_for_pattern",
      "mcp__serena__write_memory",

      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_type",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_wait_for",
      "mcp__playwright__browser_close",
      "mcp__playwright__browser_take_screenshot",

      "mcp__claude_ai_Slack__slack_search_public_and_private",
      "mcp__claude_ai_Slack__slack_read_thread"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(printenv:*)",

      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",

      "Bash(chezmoi apply --force:*)",
      "Bash(chezmoi apply -f:*)",

      "Bash(npm uninstall:*)",
      "Bash(npm remove:*)",

      "Bash(psql:*)",
      "Bash(mysql:*)",
      "Bash(mongod:*)",

      "Read(.env*)",
      "Read(.envrc*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/*token*)",
      "Read(**/*_key)",
      "Write(.env*)",
      "Write(**/secrets/**)",

      "mcp__supabase__execute_sql",
      "mcp__notionApi__API-create-a-comment",
      "mcp__notionApi__API-create-a-data-source",
      "mcp__notionApi__API-delete-a-block",
      "mcp__notionApi__API-move-page",
      "mcp__notionApi__API-patch-block-children",
      "mcp__notionApi__API-patch-page",
      "mcp__notionApi__API-post-page",
      "mcp__notionApi__API-update-a-block",
      "mcp__notionApi__API-update-a-data-source"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "afplay ~/Documents/notification.wav > /dev/null 2>&1 &"
          },
          {
            "type": "command",
            "command": "~/.config/tmux/scripts/tmux-app-alert.sh set"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/tmux/scripts/tmux-app-alert.sh clear || true"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/hook_stop_words.sh ${MESSAGE}"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/sonar-secrets/build-scripts/pretool-secrets.sh",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/hook_fetch.sh ${MESSAGE}"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.git-ai/bin/git-ai checkpoint claude --hook-input stdin || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/bash_timeout_notifier.sh ${MESSAGE}"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.git-ai/bin/git-ai checkpoint claude --hook-input stdin || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/tmux/scripts/tmux-app-waiting.sh clear"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/plugins/cache/work-checkpoints-plugin/work-checkpoints/1.0.3/scripts/save-checkpoint.sh"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/plan_review_prompt.sh"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/sonar-secrets/build-scripts/prompt-secrets.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop_main_only.sh afplay ~/Documents/celebration.wav"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/stop_main_only.sh ~/.config/tmux/scripts/tmux-app-waiting.sh set"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": ["git commit:*"],
    "filesystem": {
      "allowWrite": [
        "//tmp",
        "~/.npm",
        "~/.cache",
        "~/.local/share/mise",
        "~/.claude/plugins",
        "~/.work-checkpoints",
        "~/.config/chezmoi"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.gnupg",
        "~/.config/gh"
      ]
    },
    "network": {
      "allowedDomains": [
        "registry.npmjs.org",
        "*.npmjs.org",
        "github.com",
        "*.github.com",
        "*.githubusercontent.com",
        "registry.yarnpkg.com",
        "api.anthropic.com"
      ],
      "allowUnixSockets": [],
      "allowAllUnixSockets": true,
      "allowLocalBinding": true
    }
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/statusline.js"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "work-checkpoints@work-checkpoints-plugin": true,
    "swift-lsp@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "conversation-search@yoshi47": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "yoshi47": {
      "source": {
        "source": "github",
        "repo": "yoshi47/ai-conversation-search"
      }
    }
  },
  "feedbackSurveyState": {
    "lastShownTime": 1754035909681
  }
}
