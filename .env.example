# API Keys - Copy this to .env.local and fill in your actual keys
# DO NOT commit .env.local to git

# Anthropic API Key
export ANTHROPIC_API_KEY="your-anthropic-api-key-here"

# GitHub NPM Token
export GITHUB_NPM_TOKEN="your-github-npm-token-here"

# OneLogin Password
export ONELOGIN_PASSWORD="your-onelogin-password-here"